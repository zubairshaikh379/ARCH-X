{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "Design tokens in the W3C Design Tokens (DTCG) format. THIS FILE IS THE SINGLE SOURCE OF TRUTH for the design system. Edit values here only -- do not hand-edit the generated src/index.css or src/generated/tokens.ts. The dev server regenerates them on every change (scripts/build-tokens.mjs, wired through vite.config.ts). Colors are authored as hex; the generator converts them to the `H S% L%` channels the shadcn theme expects (web) and keeps hex for mobile (tokens.ts). Every color role exists in both light and dark.",
  "color": {
    "$type": "color",
    "light": {
      "background": { "$value": "#ffffff" },
      "foreground": { "$value": "#0a0a0a" },
      "border": { "$value": "#e5e5e5" },
      "card": { "$value": "#ffffff" },
      "cardForeground": { "$value": "#0a0a0a" },
      "popover": { "$value": "#ffffff" },
      "popoverForeground": { "$value": "#0a0a0a" },
      "primary": {
        "$value": "#171717",
        "$description": "Primary brand color. Drives buttons, links, and emphasis."
      },
      "primaryForeground": { "$value": "#fafafa" },
      "secondary": { "$value": "#f5f5f5" },
      "secondaryForeground": { "$value": "#171717" },
      "muted": { "$value": "#f5f5f5" },
      "mutedForeground": { "$value": "#737373" },
      "accent": { "$value": "#f5f5f5" },
      "accentForeground": { "$value": "#171717" },
      "destructive": { "$value": "#ef4444" },
      "destructiveForeground": { "$value": "#fafafa" },
      "input": { "$value": "#e5e5e5" },
      "ring": { "$value": "#171717" },
      "chart1": { "$value": "#e8643c" },
      "chart2": { "$value": "#2aa198" },
      "chart3": { "$value": "#274b5a" },
      "chart4": { "$value": "#e4b04a" },
      "chart5": { "$value": "#f08c3c" },
      "sidebar": { "$value": "#fafafa" },
      "sidebarForeground": { "$value": "#404040" },
      "sidebarBorder": { "$value": "#e5e5e5" },
      "sidebarPrimary": { "$value": "#171717" },
      "sidebarPrimaryForeground": { "$value": "#fafafa" },
      "sidebarAccent": { "$value": "#f5f5f5" },
      "sidebarAccentForeground": { "$value": "#171717" },
      "sidebarRing": { "$value": "#171717" }
    },
    "dark": {
      "background": { "$value": "#0a0a0a" },
      "foreground": { "$value": "#fafafa" },
      "border": { "$value": "#262626" },
      "card": { "$value": "#0a0a0a" },
      "cardForeground": { "$value": "#fafafa" },
      "popover": { "$value": "#0a0a0a" },
      "popoverForeground": { "$value": "#fafafa" },
      "primary": { "$value": "#fafafa" },
      "primaryForeground": { "$value": "#171717" },
      "secondary": { "$value": "#262626" },
      "secondaryForeground": { "$value": "#fafafa" },
      "muted": { "$value": "#262626" },
      "mutedForeground": { "$value": "#a3a3a3" },
      "accent": { "$value": "#262626" },
      "accentForeground": { "$value": "#fafafa" },
      "destructive": { "$value": "#7f1d1d" },
      "destructiveForeground": { "$value": "#fafafa" },
      "input": { "$value": "#262626" },
      "ring": { "$value": "#d4d4d4" },
      "chart1": { "$value": "#3b6fe0" },
      "chart2": { "$value": "#2bbf9c" },
      "chart3": { "$value": "#f08c3c" },
      "chart4": { "$value": "#a855d6" },
      "chart5": { "$value": "#e0497a" },
      "sidebar": { "$value": "#171717" },
      "sidebarForeground": { "$value": "#f5f5f5" },
      "sidebarBorder": { "$value": "#262626" },
      "sidebarPrimary": { "$value": "#3b6fe0" },
      "sidebarPrimaryForeground": { "$value": "#ffffff" },
      "sidebarAccent": { "$value": "#262626" },
      "sidebarAccentForeground": { "$value": "#f5f5f5" },
      "sidebarRing": { "$value": "#d4d4d4" }
    }
  },
  "typography": {
    "fontFamily": {
      "$type": "fontFamily",
      "sans": {
        "$value": ["Inter", "sans-serif"],
        "$description": "Default UI and body typeface."
      },
      "serif": { "$value": ["Georgia", "serif"] },
      "mono": { "$value": ["Menlo", "monospace"] }
    }
  },
  "radius": {
    "$type": "dimension",
    "base": {
      "$value": "0.5rem",
      "$description": "Base corner radius; sm/md/lg/xl derive from this in the theme."
    }
  },
  "spacing": {
    "$type": "dimension",
    "base": {
      "$value": "0.25rem",
      "$description": "Base spacing step the shadcn components multiply."
    }
  }
}
