# Supabase project credentials (used by src/lib/supabase.ts).
# Find them in your Supabase dashboard → Project Settings → API.
# The anon key is safe to ship to the browser AS LONG AS Row Level Security is
# enabled (see supabase/migrations/0001_auth_and_rls.sql).
# Set these in Vercel (or your host) to point the app at your own project.
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# APP_URL: The URL where this app is hosted.
# Used for self-referential links and OAuth callbacks.
APP_URL="https://your-production-url.com"
