# Exclude local environment files containing secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# Exclude git directories and CI/CD configurations
.git
.github

# Exclude node modules and temporary files
node_modules
npm-debug.log
yarn-debug.log
yarn-error.log
.pnpm-debug.log

# Exclude local builds and caches
dist
.vercel
.cache
.vite
